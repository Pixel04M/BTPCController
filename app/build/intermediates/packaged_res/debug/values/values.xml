<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="accent">#58A6FF</color>
    <color name="background">#0D1117</color>
    <color name="badge_bg">#1A58A6FF</color>
    <color name="badge_stroke">#3358A6FF</color>
    <color name="black">#FF000000</color>
    <color name="card_background">#161B22</color>
    <color name="card_stroke">#30363D</color>
    <color name="connect_color">#1F6FEB</color>
    <color name="green">#3FB950</color>
    <color name="hint">#6E7681</color>
    <color name="input_background">#0D1117</color>
    <color name="log_background">#010409</color>
    <color name="log_text">#B0BFC9</color>
    <color name="purple_200">#FFBB86FC</color>
    <color name="purple_500">#FF6200EE</color>
    <color name="purple_700">#FF3700B3</color>
    <color name="red">#DA3633</color>
    <color name="start_color">#238636</color>
    <color name="teal_200">#FF03DAC5</color>
    <color name="teal_700">#FF018786</color>
    <color name="white">#E6EDF3</color>
    <color name="yellow">#D29922</color>
    <string name="app_name">BT PC Controller</string>
    <style name="Theme.BTPCController" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryVariant">@color/connect_color</item>
        <item name="colorOnPrimary">@color/white</item>

        
        <item name="colorSecondary">@color/green</item>
        <item name="colorSecondaryVariant">@color/green</item>
        <item name="colorOnSecondary">@color/white</item>

        
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/card_background</item>
        <item name="colorOnBackground">@color/white</item>
        <item name="colorOnSurface">@color/white</item>

        
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">false</item>

        
        <item name="android:textColorHint">@color/hint</item>
    </style>
</resources>